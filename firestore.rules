rules_version = '2';

// Open rules for a collaborative art canvas (no auth).
// Tighten these before a public launch if needed.
service cloud.firestore {
  match /databases/{database}/documents {
    match /notes/{noteId} {
      allow read, write: if true;
    }
    match /images/{imageId} {
      allow read, write: if true;
    }
    match /drawings/{drawingId} {
      allow read, write: if true;
    }
  }
}
